{
  "functions": {
    "api/**/*.{js,ts}": {
      "runtime": "nodejs20.x"
    }
  },
  "crons": [
    { "path": "/api/cron-run-reminders", "schedule": "0 14 * * *" }
  ],
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build && rm -rf ../build && mkdir -p ../build && cp -r dist/. ../build/",
  "outputDirectory": "build"
}
